{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": [
			"DOM",
			"ESNext",
			"ES2022"
		],
		"types": ["node", "mocha"],
		"outDir": "out",
		"sourceMap": true,
		"strict": true,
		"rootDir": "src",
	},
	"exclude": [
		"node_modules",
		".vscode-test"
	],
	"include": [
		"src/**/*",
		"src/test/**/*"
	]
}
