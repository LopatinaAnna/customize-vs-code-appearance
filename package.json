{
  "name": "customize-vs-code-appearance",
  "displayName": "Customize VS Code Appearance",
  "description": "Personalize colors in the Global or Workspace scope for UI elements, editor settings, and layout preferences with live preview. Preview version. Development is in progress.",
  "version": "1.0.9",
  "icon": "media/edit-sparkle128.png",
  "publisher": "AnnaLopatina",
  "author": {
    "name": "Anna Lopatina",
    "email": "annalopatina.dev@outlook.com"
  },
  "preview": true,
  "galleryBanner.color": {
    "color": "#007acc",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "keywords": [
    "vscode",
    "customize",
    "appearance",
    "theme",
    "color",
    "personalize",
    "ui",
    "editor",
    "layout"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "styleCustomizer",
          "title": "Customize VS Code Appearance",
          "icon": "media/edit-sparkle.svg"
        }
      ]
    },
    "views": {
      "styleCustomizer": [
        {
          "id": "styleCustomizerView",
          "name": "",
          "type": "webview",
          "icon": "media/edit-sparkle.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && npm run copy-webview",
    "copy-webview": "copyfiles -u 2 src/webview/* out/webview",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.104.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.34.0",
    "typescript": "^5.9.2",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "copyfiles": "^2.4.1"
  }
}